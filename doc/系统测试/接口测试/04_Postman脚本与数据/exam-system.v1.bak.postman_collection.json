	"item": [
		{
			"name": "📋 Setup · 前置准备",
			"description": "登录获取 3 个角色的 Token，并准备测试数据 ID（examId / paperId 等）。\n\n**必须先跑这个文件夹**，后续所有用例依赖这里设置的环境变量。",
			"item": [
				{
					"name": "✅ Setup-1 · ADMIN 登录获取 Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('HTTP 状态码为 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('业务码 code=200 (成功)', () => pm.expect(json.code).to.equal(200));",
									"pm.test('返回 token 字段', () => pm.expect(json.data).to.have.property('token').that.is.a('string').and.not.empty);",
									"pm.test('返回 userInfo.roleCode = ADMIN', () => pm.expect(json.data.userInfo.roleCode).to.equal('ADMIN'));",
									"pm.test('响应时间 < 1000ms', () => pm.expect(pm.response.responseTime).to.be.below(1000));",
									"pm.environment.set('adminToken', json.data.token);",
									"console.log('✅ adminToken 已保存');"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{adminUser}}\",\n  \"password\": \"{{adminPass}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
