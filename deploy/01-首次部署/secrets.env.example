# ============================================================
# 在线考试系统 — 敏感环境变量模板
#
# ⚠️ 安全警告：
#   1. 此文件是**模板**，真正的 secrets.env 不能纳入 Git 版本控制
#   2. 部署时复制为 /etc/exam-system/secrets.env，权限 600（仅 root 可读）
#   3. 所有密码使用 openssl rand 生成，不要用"记得住的"密码
#   4. 密码泄露后立即全部重新生成 + systemctl restart exam-system
#
# 部署步骤（在服务器上执行）：
#   sudo mkdir -p /etc/exam-system
#   sudo chmod 700 /etc/exam-system
#   sudo cp secrets.env.example /etc/exam-system/secrets.env
#   sudo chmod 600 /etc/exam-system/secrets.env
#   sudo chown root:root /etc/exam-system/secrets.env
#   sudo vim /etc/exam-system/secrets.env   # 填入真实密码
#
# 密码生成命令（推荐）：
#   DB/Redis 密码:  openssl rand -base64 24 | tr -d '=/+' | head -c 24
#   JWT Secret:    openssl rand -base64 48 | tr -d '\n'
# ============================================================

# ---------- MySQL（应用用户） ----------
# 只授权 online_exam_system 库，不是 root
DB_USER=exam_app
DB_PASSWORD=CHANGE_ME_TO_RANDOM_STRING_FROM_OPENSSL_RAND

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_TO_RANDOM_STRING_FROM_OPENSSL_RAND

# ---------- JWT ----------
# ⚠️ 至少 32 字节（256 bits），建议 48 字节
# 生成：openssl rand -base64 48 | tr -d '\n'
JWT_SECRET=CHANGE_ME_TO_AT_LEAST_32_BYTE_RANDOM_STRING_FROM_OPENSSL_RAND_BASE64_48

# ---------- 百度语音识别（可选） ----------
# 不用则全部留空。禁止把 API Key 硬编码到代码里。
# 申请地址：https://console.bce.baidu.com/ai/
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ---------- CORS / WebSocket 允许域名白名单 ----------
# 多个域名用英文逗号分隔，含协议和端口（如非 80/443）
# 开发阶段可加 http://localhost:3000
#
# 示例（双轨部署）：
# APP_CORS_ORIGINS=https://kimi888.xyz,https://www.kimi888.xyz,https://kimi123.site
APP_CORS_ORIGINS=https://kimi888.xyz,https://kimi123.site,https://kimi666.online
