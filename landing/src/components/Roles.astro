---
import { ROLES } from '../consts'
import Icon from './Icon.astro'
import ProductMock from './ProductMock.astro'
---

<section id="roles" class="mx-auto max-w-[1120px] px-6 py-24">
  <div class="reveal max-w-2xl">
    <span class="text-[13px] font-medium text-muted">三端角色</span>
    <h2 class="mt-3 text-[2rem] leading-tight md:text-[2.35rem]">同一套系统，三种界面</h2>
    <p class="mt-4 text-[15px] leading-[1.8] text-body">
      登录后由角色码驱动动态路由，前端按角色装配菜单与页面，后端在接口层校验权限，三端互不越界。
    </p>
  </div>

  <div class="mt-16 space-y-20">
    {
      ROLES.map((role, i) => (
        <div class={`grid items-center gap-10 lg:grid-cols-2 lg:gap-14 ${i % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}>
          <div class="reveal">
            <div class="flex items-center gap-2">
              <span class="omr omr-on h-2 w-2"></span>
              <span class="text-[13px] font-medium text-accent-600">{role.name}</span>
            </div>
            <h3 class="mt-3 text-[1.5rem] text-ink">{role.desc}</h3>
            <ul class="mt-5 grid gap-2.5 sm:grid-cols-2">
              {role.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[14px] leading-relaxed text-body">
                  <Icon name="check" class="mt-1 h-4 w-4 flex-none text-accent-500" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="reveal">
            <ProductMock type={role.mock} />
          </div>
        </div>
      ))
    }
  </div>
</section>
