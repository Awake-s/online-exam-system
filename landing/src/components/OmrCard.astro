---
// Signature 之二：准考证 + 答题卡（OMR）复合卡 —— Hero 主视觉。
// 第 3 题第 ③ 个泡用 omr-ink 在载入时"被涂上"一次（reduced-motion 下静止为实格）。
const letters = ['A', 'B', 'C', 'D']
const rows = [
  { n: 1, sel: 1 },
  { n: 2, sel: 0 },
  { n: 3, sel: 2, animate: true },
  { n: 4, sel: 3 },
  { n: 5, sel: 1 },
  { n: 6, sel: 2 }
]
---

<div class="overflow-hidden rounded-2xl border border-line bg-paper shadow-[0_28px_70px_-34px_rgba(25,24,19,0.45)]">
  <!-- 准考证抬头 -->
  <div class="flex items-center justify-between border-b border-line px-5 py-3.5">
    <div class="flex items-center gap-2">
      <span class="omr omr-on h-3 w-3"></span>
      <span class="font-display text-[15px] font-bold text-ink">在线考试系统</span>
    </div>
    <span class="font-mono text-[11px] text-muted">准考证号 2024030145</span>
  </div>

  <!-- 科目信息条 -->
  <div class="flex items-center justify-between border-b border-line bg-soft px-5 py-2.5">
    <span class="text-[13px] font-medium text-ink">计算机网络 · 期末</span>
    <span class="font-mono text-[11px] text-muted">90 分钟 · 满分 100</span>
  </div>

  <!-- 答题卡 -->
  <div class="px-5 py-4">
    <div class="flex items-center justify-between">
      <span class="text-[12px] font-medium text-muted">答题卡 · 单选</span>
      <span class="inline-flex items-center gap-1.5 rounded-md bg-[#f6ede0] px-2 py-0.5 font-mono text-[11px] font-medium text-warn">
        47:12
      </span>
    </div>

    <div class="mt-3 grid grid-cols-2 gap-x-8 gap-y-2.5">
      {
        rows.map((row) => (
          <div class="flex items-center gap-2.5">
            <span class="font-mono text-[12px] text-muted w-4 text-right">{row.n}</span>
            <div class="flex items-center gap-1.5">
              {letters.map((l, i) => {
                const filled = i === row.sel
                const animate = filled && row.animate
                return (
                  <span
                    class={`omr h-5 w-5 font-mono text-[10px] ${filled ? (animate ? 'omr-ink text-white' : 'omr-on text-white') : 'text-muted'}`}
                  >
                    {l}
                  </span>
                )
              })}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- 底部动作（与登录呼应） -->
  <div class="flex items-center justify-between border-t border-line px-5 py-3.5">
    <span class="font-mono text-[11px] text-muted">已答 6 / 12 · 自动暂存</span>
    <span class="rounded-lg bg-accent-500 px-4 py-1.5 text-[12.5px] font-medium text-white">交卷</span>
  </div>
</div>
