---
// Signature 之一：密封线分隔装置（取自试卷"密封线内不要答题"）
// 用虚线 + 装订○孔 + 居中标签，作为区段之间的分隔。
interface Props {
  label?: string
  class?: string
}
const { label = '密封线', class: className = '' } = Astro.props
---

<div class={`flex items-center gap-3 ${className}`} role="separator" aria-hidden="true">
  <span class="h-px flex-1 border-t border-dashed border-line"></span>
  <span class="omr h-1.5 w-1.5"></span>
  <span
    class="select-none text-[11px] font-medium text-muted"
    style="letter-spacing:0.4em;padding-left:0.4em;"
  >
    {label}
  </span>
  <span class="omr h-1.5 w-1.5"></span>
  <span class="h-px flex-1 border-t border-dashed border-line"></span>
</div>
