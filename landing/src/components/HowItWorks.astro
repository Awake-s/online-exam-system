---
import { STEPS } from '../consts'
---

<section id="how" class="border-b border-line">
  <div class="mx-auto max-w-[1120px] px-6 py-24">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-xl">
        <span class="text-[13px] font-medium text-muted">使用流程</span>
        <h2 class="mt-3 text-[2rem] leading-tight md:text-[2.35rem]">一场考试，六步跑完</h2>
      </div>
      <p class="text-[14px] text-muted">教师走前三步与第五步，学生只面对第四步。</p>
    </div>

    <!-- 步骤轨：编号 + 连接线，非功能卡网格 -->
    <ol class="reveal mt-14 grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-3 lg:grid-cols-6 lg:gap-x-3">
      {
        STEPS.map((s, i) => (
          <li class="relative">
            <div class="flex items-center">
              <span class="tnum flex h-9 w-9 flex-none items-center justify-center rounded-full border border-accent-200 bg-white text-[13px] font-semibold text-accent-600">
                {s.n}
              </span>
              {i < STEPS.length - 1 && (
                <span class="ml-2 hidden h-px flex-1 bg-line lg:block" />
              )}
            </div>
            <h3 class="mt-4 text-[15px] text-ink">{s.title}</h3>
            <p class="mt-1.5 text-[13px] leading-relaxed text-body">{s.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
