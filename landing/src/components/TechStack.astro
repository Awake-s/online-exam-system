---
import { TECH, HIGHLIGHTS, SITE } from '../consts'
import Icon from './Icon.astro'

const HL_ICONS = ['lock', 'database', 'message', 'shield', 'activity', 'bar-chart']
---

<section id="tech" class="border-b border-line bg-soft">
  <div class="mx-auto max-w-[1120px] px-6 py-24">
    <div class="reveal max-w-2xl">
      <span class="text-[13px] font-medium text-muted">技术与工程</span>
      <h2 class="mt-3 text-[2rem] leading-tight md:text-[2.35rem]">不只是能跑，是按生产标准搭的</h2>
      <p class="mt-4 text-[15px] leading-[1.8] text-body">
        单体分层架构，技术选型与 <code class="rounded border border-line bg-white px-1.5 py-0.5 font-sans text-[13px] text-body">pom.xml</code> / <code class="rounded border border-line bg-white px-1.5 py-0.5 font-sans text-[13px] text-body">package.json</code> 一致。下面这些是面试官会追问的细节。
      </p>
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-[7fr_5fr] lg:gap-16">
      <!-- 工程亮点（主） -->
      <div class="reveal">
        <h3 class="text-[13px] font-medium text-muted">工程亮点</h3>
        <ul class="mt-4 divide-y divide-line border-t border-line">
          {
            HIGHLIGHTS.map((h, i) => (
              <li class="flex gap-3.5 py-4">
                <span class="mt-0.5 flex h-8 w-8 flex-none items-center justify-center rounded-lg bg-white text-accent-600 ring-1 ring-line">
                  <Icon name={HL_ICONS[i]} class="h-[17px] w-[17px]" />
                </span>
                <div>
                  <h4 class="text-[14.5px] font-semibold text-ink">{h.title}</h4>
                  <p class="mt-0.5 text-[13.5px] leading-relaxed text-body">{h.text}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- 技术栈（次） -->
      <div class="reveal">
        <h3 class="text-[13px] font-medium text-muted">技术栈</h3>
        <dl class="mt-4 overflow-hidden rounded-xl border border-line bg-white">
          {
            TECH.map((t, i) => (
              <div class={`flex items-center justify-between px-4 py-3 ${i > 0 ? 'border-t border-line' : ''}`}>
                <dt class="text-[14px] font-medium text-ink">{t.name}</dt>
                <dd class="text-[12.5px] text-muted">{t.role}</dd>
              </div>
            ))
          }
        </dl>
        <a
          href={SITE.docsUrl}
          class="mt-5 inline-flex items-center gap-1.5 text-[14px] font-medium text-accent-600 transition-colors hover:text-accent-700"
        >
          完整技术文档与压测报告
          <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>
</section>
