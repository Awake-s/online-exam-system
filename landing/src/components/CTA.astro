---
import { SITE, DEMO_ACCOUNTS } from '../consts'
import Icon from './Icon.astro'
---

<section class="mx-auto max-w-[1120px] px-6 py-24">
  <div class="reveal relative overflow-hidden rounded-2xl bg-ink px-8 py-16 md:px-14">
    <!-- 单点径向高光，非多段渐变 -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(50% 80% at 85% 0%, rgba(194,58,43,0.30), transparent 60%);"
    >
    </div>
    <div class="relative max-w-2xl">
      <h2 class="text-[2rem] leading-tight text-white md:text-[2.4rem]">
        打开一个账号，比看十张截图快
      </h2>
      <p class="mt-4 max-w-xl text-[15.5px] leading-[1.8] text-white/70">
        用下面的账号直接登录已部署的系统，把组卷、作答、阅卷、成绩分析挨个点一遍。
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={SITE.demoUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3 text-[15px] font-medium text-ink transition-colors duration-200 hover:bg-white/90"
        >
          在线体验
          <Icon name="arrow-right" class="h-4 w-4" />
        </a>
        <a
          href={SITE.githubUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border border-white/25 px-5 py-3 text-[15px] font-medium text-white transition-colors duration-200 hover:bg-white/10"
          >GitHub 源码</a
        >
        <a
          href={SITE.docsUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border border-white/25 px-5 py-3 text-[15px] font-medium text-white transition-colors duration-200 hover:bg-white/10"
          >技术文档</a
        >
      </div>
      <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-[13px] text-white/60">
        {
          DEMO_ACCOUNTS.map((a) => (
            <span class="inline-flex items-center gap-1.5">
              <span class="text-white/80">{a.role}</span>
              <code class="rounded border border-white/15 bg-white/5 px-1.5 py-0.5 font-mono text-[12px] text-white/80">
                {a.username} / {a.password}
              </code>
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
