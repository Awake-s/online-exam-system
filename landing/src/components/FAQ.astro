---
import { FAQS } from '../consts'
---

<section id="faq" class="border-b border-line">
  <div class="mx-auto grid max-w-[1120px] gap-10 px-6 py-24 lg:grid-cols-[4fr_8fr] lg:gap-16">
    <div class="reveal lg:pt-1">
      <span class="text-[13px] font-medium text-muted">常见问题</span>
      <h2 class="mt-3 text-[2rem] leading-tight md:text-[2.25rem]">还想确认的几件事</h2>
    </div>

    <div class="reveal divide-y divide-line border-y border-line">
      {
        FAQS.map((f) => (
          <details class="group py-4 [&_summary]:list-none">
            <summary class="flex cursor-pointer items-center justify-between gap-4 text-[15.5px] font-semibold text-ink">
              {f.q}
              <span
                class="omr h-4 w-4 flex-none transition-colors duration-200 group-open:border-accent-500 group-open:bg-accent-500"
              ></span>
            </summary>
            <p class="mt-3 max-w-2xl text-[14px] leading-[1.8] text-body">{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
