---
import { SITE, NAV } from '../consts'
import SealLine from './SealLine.astro'
---

<footer class="bg-paper">
  <div class="mx-auto max-w-[1120px] px-6 pb-12">
    <SealLine label="卷尾" class="pb-10" />
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <a href="#top" class="flex items-center gap-2.5">
        <span class="omr omr-on h-3.5 w-3.5"></span>
        <span class="font-display text-[16px] font-bold text-ink">{SITE.name}</span>
      </a>

      <ul class="flex flex-wrap items-center gap-x-7 gap-y-2 text-[13.5px] text-muted">
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} class="transition-colors duration-200 hover:text-ink">
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href={SITE.docsUrl} class="transition-colors duration-200 hover:text-ink">文档</a>
        </li>
        <li>
          <a
            href={SITE.githubUrl}
            target="_blank"
            rel="noopener"
            class="transition-colors duration-200 hover:text-ink">GitHub</a
          >
        </li>
      </ul>
    </div>

    <div class="mt-9 flex flex-col gap-1.5 border-t border-line pt-6 text-[12.5px] text-muted sm:flex-row sm:items-center sm:justify-between">
      <p>基于 MIT 协议开源 · 仅用于学习与个人作品展示</p>
      <p>© {SITE.year} {SITE.name} · by {SITE.author}</p>
    </div>
  </div>
</footer>
