---
import { SITE, NAV } from '../consts'
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/85 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-[1120px] items-center justify-between px-6">
    <!-- 品牌标记：涂卡 ● + 宋体站名 -->
    <a href="#top" class="flex items-center gap-2.5">
      <span class="omr omr-on h-3.5 w-3.5"></span>
      <span class="font-display text-[16px] font-bold text-ink">{SITE.name}</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-[13.5px] text-muted transition-colors duration-200 hover:text-ink"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-4">
      <a
        href={SITE.docsUrl}
        target="_blank"
        rel="noopener"
        class="hidden text-[13.5px] text-muted transition-colors duration-200 hover:text-ink sm:inline"
        >技术文档</a
      >
      <a
        href={SITE.githubUrl}
        target="_blank"
        rel="noopener"
        class="hidden text-[13.5px] text-muted transition-colors duration-200 hover:text-ink sm:inline"
        >GitHub</a
      >
      <a
        href={SITE.demoUrl}
        target="_blank"
        rel="noopener"
        class="rounded-lg bg-accent-500 px-4 py-2 text-[13.5px] font-medium text-white transition-colors duration-200 hover:bg-accent-600"
        >在线体验</a
      >
    </div>
  </nav>
</header>
